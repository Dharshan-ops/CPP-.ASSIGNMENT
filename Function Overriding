#include <iostream>
using namespace std;

// Base class
class Employee
{
public:
    virtual void calculateSalary()
    {
        cout << "Salary calculation for general employee" << endl;
    }
};

// Derived class 1
class Manager : public Employee
{
public:
    void calculateSalary()
    {
        int basic = 50000;
        int bonus = 10000;
        cout << "Manager Salary = " << basic + bonus << endl;
    }
};

// Derived class 2
class Developer : public Employee
{
public:
    void calculateSalary()
    {
        int basic = 40000;
        int bonus = 5000;
        cout << "Developer Salary = " << basic + bonus << endl;
    }
};

int main()
{
    Employee *e;

    Manager m;
    Developer d;

    e = &m;
    e->calculateSalary();

    e = &d;
    e->calculateSalary();

    return 0;
}
