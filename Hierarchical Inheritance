#include <iostream>
using namespace std;

// Base class
class Shape
{
public:
    void display()
    {
        cout << "This is the base class Shape" << endl;
    }
};

// Derived class 1
class Rectangle : public Shape
{
public:
    void areaRectangle()
    {
        cout << "Area of Rectangle = length * breadth" << endl;
    }
};

// Derived class 2
class Triangle : public Shape
{
public:
    void areaTriangle()
    {
        cout << "Area of Triangle = 0.5 * base * height" << endl;
    }
};

int main()
{
    Rectangle r;
    Triangle t;

    r.display();
    r.areaRectangle();

    t.display();
    t.areaTriangle();

    return 0;
}
