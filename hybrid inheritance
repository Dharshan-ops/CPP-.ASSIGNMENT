#include <iostream>
using namespace std;

// Base class
class A
{
public:
    void displayA()
    {
        cout << "This is class A" << endl;
    }
};

// Derived from A
class B : public A
{
public:
    void displayB()
    {
        cout << "This is class B" << endl;
    }
};

// Derived from A
class C
{
public:
    void displayC()
    {
        cout << "This is class C" << endl;
    }
};

// Derived from B and C
class D : public B, public C
{
public:
    void displayD()
    {
        cout << "This is class D" << endl;
    }
};

int main()
{
    D obj;

    obj.displayA();
    obj.displayB();
    obj.displayC();
    obj.displayD();

    return 0;
}
